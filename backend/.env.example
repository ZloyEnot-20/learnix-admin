# Copy to .env — never commit .env
NODE_ENV=development
PORT=4100

MONGODB_URI=mongodb://127.0.0.1:27017
MONGODB_DB=learnix_platform
TENANT_MONGODB_DB=ielts

# JWT — use long random strings in production (e.g. `openssl rand -hex 48`)
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars

# Comma-separated admin panel URLs
CORS_ORIGINS=http://localhost:3001
# Allow any Origin (skips CORS_ORIGINS check). Dev/debug only — not for public production.
# CORS_DISABLED=true

# Seed: platform super-admin created by `npm run seed`
SEED_ADMIN_EMAIL=admin@learnix.platform
SEED_ADMIN_PASSWORD=change_me_admin_password_min_12

TELEGRAM_BOT_TOKEN=
